<!--
  Launcher icon foreground: a simple clock face with two hands plus a small
  "sound wave" to nod at the talking/speaking purpose. Drawn in the dark
  on-amber color (#2A1D00) so it reads against the amber icon background.
  108x108dp is the adaptive-icon canvas; the ~66dp center is the safe zone
  the launcher never masks off. Placeholder art — the project may replace it
  with a final icon later (see the design handoff README).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Clock rim -->
    <path
        android:strokeColor="#2A1D00"
        android:strokeWidth="5"
        android:fillColor="#00000000"
        android:pathData="M50,32 m-22,0 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0" />
    <!-- Hour hand -->
    <path
        android:strokeColor="#2A1D00"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:pathData="M50,32 L50,20" />
    <!-- Minute hand -->
    <path
        android:strokeColor="#2A1D00"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:pathData="M50,32 L62,38" />
    <!-- Sound waves radiating from the clock (the "talking" cue) -->
    <path
        android:strokeColor="#2A1D00"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M74,24 a14,14 0 0,1 0,16" />
    <path
        android:strokeColor="#2A1D00"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M79,19 a22,22 0 0,1 0,26" />
</vector>
