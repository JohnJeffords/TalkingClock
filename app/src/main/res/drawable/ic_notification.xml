<!--
  Status-bar notification icon. Android renders these as pure white
  silhouettes, so only the alpha channel matters — a simple clock outline
  with a speaking wave, echoing the launcher icon. 24dp grid.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Clock rim -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:fillColor="#00000000"
        android:pathData="M10,12 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0" />
    <!-- Hands -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M10,12 L10,8 M10,12 L13,14" />
    <!-- Speech wave -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M19.5,9 a5,5 0 0,1 0,6" />
</vector>
