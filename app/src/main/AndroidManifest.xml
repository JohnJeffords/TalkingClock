<?xml version="1.0" encoding="utf-8"?>
<!--
  App manifest. The permission set is EXACTLY these three, and the CI
  "manifest guard" fails the build if anything outside the allowlist — above
  all INTERNET — ever appears here (docs/TESTING_AND_CI.md, DECISIONS.md
  D-006/D-020):

  - FOREGROUND_SERVICE(+_MEDIA_PLAYBACK): lets announcements keep speaking
    with the screen off / app backgrounded (a "normal" permission — granted
    at install, no user prompt).
  - POST_NOTIFICATIONS: a runtime prompt on Android 13+, asked once with an
    in-app explanation, so the service's status notification is visible.
    Denial is honored: everything still works, just without the notification.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".TalkingClockApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TalkingClock">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TalkingClock">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The speaking clock's keep-alive shell. mediaPlayback is the FGS
             type for ongoing audible output (required on API 34+); the
             service holds no other capabilities and is not exported. -->
        <service
            android:name=".service.AnnouncerService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />
    </application>

</manifest>
