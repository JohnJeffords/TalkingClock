<?xml version="1.0" encoding="utf-8"?>
<!--
  App manifest. The permission set is EXACTLY what's listed, and the CI
  "manifest guard" fails the build if anything outside the allowlist — above
  all INTERNET — ever appears here (docs/TESTING_AND_CI.md, DECISIONS.md
  D-006/D-020):

  - FOREGROUND_SERVICE(+_MEDIA_PLAYBACK): announcements keep speaking with
    the screen off (normal permission — granted at install, no prompt).
  - POST_NOTIFICATIONS: runtime prompt on 13+, asked once with an in-app
    explanation. Denial honored: everything works, just less visible.
  - Alarm set (D-020 — added WITH the alarm feature, the documented veto
    point): USE_EXACT_ALARM (13+, grant-free for alarm-clock apps) with
    SCHEDULE_EXACT_ALARM as the pre-13 equivalent; USE_FULL_SCREEN_INTENT
    so the ringing screen pops over the lockscreen; RECEIVE_BOOT_COMPLETED
    to re-book alarms after a reboot; VIBRATE for the ringing buzz.
    Still no INTERNET — ever.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
      REQUIRED for text-to-speech to work at all on Android 11+ (API 30+).
      Since API 30, "package visibility" filtering hides other apps from us
      unless we declare that we intend to interact with them. A text-to-
      speech engine (SherpaTTS, RHVoice, eSpeak NG, Google TTS, …) is a
      separate app exposing a TTS_SERVICE; without this <queries> block the
      OS makes those services invisible, so TextToSpeech.getEngines() comes
      back empty and — worse — TextToSpeech can't bind to the engine, its
      init reports failure, and we wrongly conclude "no engine installed."
      This is exactly the MVP: the clock must speak through the system TTS.
      Do NOT remove (TtsSpeakerManifestTest guards it).
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:name=".TalkingClockApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TalkingClock">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TalkingClock">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The speaking clock's keep-alive shell. mediaPlayback is the FGS
             type for ongoing audible output (required on API 34+); the
             service holds no other capabilities and is not exported. -->
        <service
            android:name=".service.AnnouncerService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- The full-screen ringing UI: shows over the lockscreen, wakes
             the screen — launched only by our own full-screen intent. -->
        <activity
            android:name=".alarm.AlarmRingingActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.TalkingClock" />

        <!-- Fired by AlarmManager when an alarm is due. Not exported: only
             our own PendingIntents can reach it. -->
        <receiver
            android:name=".alarm.AlarmReceiver"
            android:exported="false" />

        <!-- Re-books alarms after a reboot (AlarmManager forgets them). -->
        <receiver
            android:name=".alarm.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
